#include <stdio.h>
#include <stdlib.h>

int main()
{
    int N=4;//Define el tamaño de mi arreglo
    float temp[N];//Se defina el arreglo
    temp[0] = 20.5;
    temp[1] = 19.2;
    printf("Temperatura 0: %.2f\n", temp[0]);
    printf("Temperatura 1: %.2f\n", temp[1]);
    ////-For para pedir datos-//////
    for(int i = 0; i < N; i++){
    printf("Ingresa la temp %d:", i+1);
    scanf("%f", &temp[i]);
    }
    ////-For para imprimir datos/////
    for(int i=0; i<N; i++){
    printf("temperatura %.2f\n", temp[i]);
    }
    return 0;
}
